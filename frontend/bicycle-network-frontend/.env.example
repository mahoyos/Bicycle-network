# API Gateway base URL - all microservices go through this gateway
VITE_API_GATEWAY_URL=http://localhost:8080

# Service path prefixes (as configured in the API gateway)
VITE_AUTH_PREFIX=/auth
VITE_BIKES_PREFIX=/bikes
VITE_RENTALS_PREFIX=/rentals
VITE_GEOLOCATION_PREFIX=/api/v1
VITE_EVENTS_PREFIX=/events
