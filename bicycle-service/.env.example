DATABASE_URL=postgresql://user:password@localhost:5432/bikes_db
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JWT_PUBLIC_KEY=<RSA public key in PEM format>
JWT_ALGORITHM=RS256
APP_PORT=8000

# Set to "true" to skip JWT validation (local development only)
DISABLE_AUTH=false

# Set to "false" when running migrations via the Kubernetes Job instead of app startup
RUN_MIGRATIONS=true
